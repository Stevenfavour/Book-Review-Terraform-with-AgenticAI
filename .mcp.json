{
  "mcpServers": {
    "terraform": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-v",
        "C:/dev/terraform:/workspace",
        "-w",
        "/workspace",
        "hashicorp/terraform-mcp-server"
      ]
    },
    "aws": {
       "command": "uvx", 
      "timeout": 100000, 
      "transport": "stdio", 
      "args": [ 
        "mcp-proxy-for-aws@latest", 
        "https://aws-mcp.us-east-1.api.aws/mcp", 
        "--metadata", "AWS_REGION=us-west-2"
    ]
    },

  "Azure MCP Server": {
  "command": "npx",
  "args": [
    "-y",
    "@azure/mcp@latest",
    "server",
    "start"
  ]
}
  }
}
